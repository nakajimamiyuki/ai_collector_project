# ============================================
# AI Collector Project - Environment Variables
# ============================================
# 复制此文件为 .env 并填入你的真实凭证
# cp .env.example .env

# ----- RSSHub 配置 (可选, 当前版本已弃用) -----
RSSHUB_URL=http://localhost:1201

# ----- LLM 配置 (火山引擎 Coding Plan) -----
# 在火山引擎控制台 → API Key 管理 中创建
LLM_API_KEY=your_volcano_api_key_here

# 火山 Coding Plan 专属 Base URL (注意有 /coding/ 路径)
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3

# Coding Plan 套餐内的模型名称
LLM_MODEL=kimi-k2.6

# ----- 数据库路径 -----
DB_PATH=data/collector.db

# ----- Bilibili 反爬 (可选, v1.1 新增) -----
# 当 monitor.py 的 requests 直接请求 B 站 API 命中 412/-799/-412 等错误码时，
# 系统会自动 fallback 到 Playwright。如果你能提供登录态 cookie，requests 路径
# 也能更稳定地拿到数据：
#   1. 浏览器登录 bilibili.com
#   2. F12 -> Network -> 任意 api.bilibili.com 请求 -> Request Headers -> Cookie
#   3. 整段复制粘贴到下面（保留双引号）
# 不填也能跑，会走 Playwright fallback。
# BILI_COOKIE="buvid3=xxx; SESSDATA=xxx; bili_jct=xxx; ..."
